{
  "name": "SFC_Snake_Advanced",
  "steps": [
    {
      "id": "step_init",
      "name": "Init",
      "initial": true,
      "x": 300,
      "y": 50,
      "actions": [
        {
          "id": "action_init",
          "name": "InitSnake",
          "qualifier": "N",
          "body": "// Initialize 8-LED Snake System\nposition := 0;\ndirection := 1;\n// Turn off all LEDs\n%QX0.0 := FALSE;\n%QX0.1 := FALSE;\n%QX0.2 := FALSE;\n%QX0.3 := FALSE;\n%QX0.4 := FALSE;\n%QX0.5 := FALSE;\n%QX0.6 := FALSE;\n%QX0.7 := FALSE;"
        }
      ]
    },
    {
      "id": "step_running",
      "name": "Running",
      "x": 300,
      "y": 200,
      "actions": [
        {
          "id": "action_update_position",
          "name": "UpdatePosition",
          "qualifier": "N",
          "body": "// Update snake position\nposition := position + direction;\n\n// Turn off all LEDs first\n%QX0.0 := FALSE;\n%QX0.1 := FALSE;\n%QX0.2 := FALSE;\n%QX0.3 := FALSE;\n%QX0.4 := FALSE;\n%QX0.5 := FALSE;\n%QX0.6 := FALSE;\n%QX0.7 := FALSE;\n\n// Turn on LED at current position\nCASE position OF\n  0: %QX0.0 := TRUE;\n  1: %QX0.1 := TRUE;\n  2: %QX0.2 := TRUE;\n  3: %QX0.3 := TRUE;\n  4: %QX0.4 := TRUE;\n  5: %QX0.5 := TRUE;\n  6: %QX0.6 := TRUE;\n  7: %QX0.7 := TRUE;\nEND_CASE;"
        },
        {
          "id": "action_check_bounds",
          "name": "CheckBounds",
          "qualifier": "N",
          "body": "// Check boundaries and reverse direction\nIF position >= 7 THEN\n  direction := -1;\nELSIF position <= 0 THEN\n  direction := 1;\nEND_IF;"
        }
      ]
    },
    {
      "id": "step_wait",
      "name": "Wait",
      "x": 300,
      "y": 350,
      "actions": [
        {
          "id": "action_delay",
          "name": "DelayTimer",
          "qualifier": "L",
          "body": "// Wait for next step",
          "time": 300
        }
      ]
    },
    {
      "id": "step_stopped",
      "name": "Stopped",
      "x": 300,
      "y": 500,
      "actions": [
        {
          "id": "action_stop_all",
          "name": "StopAll",
          "qualifier": "N",
          "body": "// Turn off all LEDs\n%QX0.0 := FALSE;\n%QX0.1 := FALSE;\n%QX0.2 := FALSE;\n%QX0.3 := FALSE;\n%QX0.4 := FALSE;\n%QX0.5 := FALSE;\n%QX0.6 := FALSE;\n%QX0.7 := FALSE;"
        }
      ]
    }
  ],
  "transitions": [
    {
      "id": "trans_init_to_running",
      "name": "T_Start",
      "condition": "start_button = TRUE AND stop_button = FALSE",
      "sourceStepId": "step_init",
      "targetStepId": "step_running"
    },
    {
      "id": "trans_running_to_wait",
      "name": "T_NextStep",
      "condition": "TRUE",
      "sourceStepId": "step_running",
      "targetStepId": "step_wait"
    },
    {
      "id": "trans_wait_to_running",
      "name": "T_DelayDone",
      "condition": "stop_button = FALSE",
      "sourceStepId": "step_wait",
      "targetStepId": "step_running"
    },
    {
      "id": "trans_wait_to_stopped",
      "name": "T_Stop",
      "condition": "stop_button = TRUE",
      "sourceStepId": "step_wait",
      "targetStepId": "step_stopped"
    },
    {
      "id": "trans_running_to_stopped",
      "name": "T_EmergencyStop",
      "condition": "stop_button = TRUE",
      "sourceStepId": "step_running",
      "targetStepId": "step_stopped",
      "priority": 1
    },
    {
      "id": "trans_stopped_to_init",
      "name": "T_Reset",
      "condition": "reset_button = TRUE",
      "sourceStepId": "step_stopped",
      "targetStepId": "step_init"
    }
  ],
  "variables": [
    {
      "name": "position",
      "type": "INT",
      "initialValue": "0",
      "comment": "Current LED position (0-7)"
    },
    {
      "name": "direction",
      "type": "INT",
      "initialValue": "1",
      "comment": "Movement direction: 1 = forward, -1 = backward"
    },
    {
      "name": "start_button",
      "type": "BOOL",
      "initialValue": "FALSE",
      "comment": "Button to start the snake"
    },
    {
      "name": "stop_button",
      "type": "BOOL",
      "initialValue": "FALSE",
      "comment": "Button to stop the snake"
    },
    {
      "name": "reset_button",
      "type": "BOOL",
      "initialValue": "FALSE",
      "comment": "Button to reset the snake"
    }
  ],
  "metadata": {
    "author": "Trust Platform",
    "version": "1.0.0",
    "description": "Advanced 8-LED snake pattern with bidirectional movement using SFC for EL2008",
    "created": "2026-03-01T00:00:00Z",
    "hardware": "EtherCAT EL2008 (8 Digital Outputs)"
  }
}
