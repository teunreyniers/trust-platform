    },
    {
      "name": "tick_timer",
      "type": "TIME",
      "initialValue": "T#0ms",
      "comment": "Timer for LED transitions (300ms per step)"
    }
  ],
  "metadata": {
    "author": "Trust Platform",
    "version": "1.0.0",
    "description": "Simple 8-LED snake pattern using SFC for EL2008 - LEDs move back and forth in sequence",
    "created": "2026-03-01T00:00:00Z",
